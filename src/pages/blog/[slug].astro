---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const now = new Date();
  const posts = await getCollection('blog', ({ data }) => {
    return !data.draft && data.pubDate <= now;
  });
  
  const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return sortedPosts.map((post, index) => {
    const nextPost = index > 0 ? sortedPosts[index - 1] : null;
    const prevPost = index < sortedPosts.length - 1 ? sortedPosts[index + 1] : null;

    return {
      params: { slug: post.slug },
      props: { post, nextPost, prevPost },
    };
  });
}

const { post, nextPost, prevPost } = Astro.props;

// --- PROTEÇÃO EXTRA PARA SSR ---
// Se o post não existir (caso o slug seja inválido no SSR)
// ou se a data for futura, redirecionamos para 404.
const now = new Date();
if (!post || post.data.pubDate > now || post.data.draft) {
  return Astro.redirect('/404');
}
// -------------------------------

const { Content } = await post.render();

const authors = await Promise.all(
  post.data.authors.map(async (authorRef) => await getEntry(authorRef))
);
---

<BaseLayout 
  title={post.data.title} 
  description={post.data.description} 
  image={post.data.image}
  frontmatter={post.data}
  author={authors[0]} 
>
 <article class="max-w-4xl mx-auto p-6 bg-white shadow-sm mt-10 rounded-xl">
    
    <header class="mb-8">
      <h1 class="text-4xl font-extrabold mb-4 text-gray-900 leading-tight">
        {post.data.title}
      </h1>

      <img 
        src={post.data.image.url} 
        alt={post.data.image.alt} 
        class="w-full h-[450px] object-cover rounded-xl mb-6 shadow-md"
      />
      
      <div class="flex flex-col gap-4 text-gray-600 border-b pb-6">
        
        <div class="flex flex-wrap items-center gap-4 text-sm">
          <time datetime={post.data.pubDate.toISOString()}>
            📅 {post.data.pubDate.toLocaleDateString('pt-BR', { day: 'numeric', month: 'long', year: 'numeric' })}
          </time>

          <span class="text-gray-300">|</span>

          <div class="flex gap-2">
            <strong>Por:</strong>
            {authors.map((author, index) => (
              <a href={`/authors/${author.id}/`} class="text-blue-600 hover:underline font-medium">
                {author.data.name}{index < authors.length - 1 ? ', ' : ''}
              </a>
            ))}
          </div>
        </div>

        <div class="flex flex-wrap items-center gap-4">
          <div class="flex gap-2 items-center">
            <span class="text-sm font-bold uppercase tracking-wider text-gray-400 text-[11px]">Categorias:</span>
            <!-- <div class="flex gap-2">
              {post.data.taxonomies.categories.map(cat => (
                <a href={`/categories/${cat.toLowerCase()}/`} class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs font-semibold hover:bg-blue-100 transition-colors capitalize">
                  {cat}
                </a>
              ))}
            </div> -->

            <div class="flex gap-2">
              {post.data.taxonomies.categories.map(cat => {
                // Se for referência, o ID está em cat.id. Se for string, é o próprio cat.
                const slug = typeof cat === 'string' ? cat : cat.id;
                
                return (
                  <a 
                    href={`/categories/${slug.toLowerCase()}/`} 
                    class="bg-blue-50 text-blue-700 px-3 py-1 rounded-full text-xs font-semibold hover:bg-blue-100 transition-colors capitalize"
                  >
                    {slug}
                  </a>
                )
              })}
          </div>
          </div>
        </div>

        <div class="flex gap-2 items-center">
           <span class="text-sm font-bold uppercase tracking-wider text-gray-400 text-[11px]">Tags:</span>
           <div class="flex flex-wrap gap-2">
            {post.data.taxonomies.tags.map(tag => (
              <a href={`/tags/${tag.toLowerCase()}/`} class="text-xs bg-gray-100 text-gray-600 px-2 py-1 rounded hover:bg-gray-200">
                #{tag}
              </a>
            ))}
          </div>
        </div>
      </div>
    </header>

    <div class="prose lg:prose-xl max-w-none prose-img:rounded-xl">
      <Content />
    </div>

    <footer class="mt-16 border-t pt-10">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          {prevPost && (
            <a href={`/blog/${prevPost.slug}/`} class="group block p-5 border border-gray-200 rounded-xl hover:border-blue-400 hover:bg-blue-50 transition-all">
              <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">← Post Anterior</span>
              <p class="font-bold text-gray-800 group-hover:text-blue-700">{prevPost.data.title}</p>
            </a>
          )}
        </div>

        <div class="text-right">
          {nextPost && (
            <a href={`/blog/${nextPost.slug}/`} class="group block p-5 border border-gray-200 rounded-xl hover:border-blue-400 hover:bg-blue-50 transition-all">
              <span class="text-[10px] font-bold text-gray-400 uppercase tracking-widest block mb-2">Próximo Post →</span>
              <p class="font-bold text-gray-800 group-hover:text-blue-700">{nextPost.data.title}</p>
            </a>
          )}
        </div>
      </div>
    </footer>

  </article>
</BaseLayout>