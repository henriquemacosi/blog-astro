---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths({ paginate }) {
  const now = new Date();

  // Filtragem essencial: apenas posts publicados
  const allPosts = await getCollection('blog', ({ data }) => {
    return !data.draft && data.pubDate <= now;
  });
  
  const uniqueCategoryIds = [...new Set(allPosts.flatMap(post => 
    post.data.taxonomies.categories.map(cat => typeof cat === 'string' ? cat : cat.id)
  ))];

  const paths = await Promise.all(uniqueCategoryIds.map(async (catId) => {
    const filteredPosts = allPosts
      .filter(post => 
        post.data.taxonomies.categories.some(cat => 
          (typeof cat === 'string' ? cat : cat.id) === catId
        )
      )
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    const categoryEntry = await getEntry('categories', catId.toLowerCase());
  
    return paginate(filteredPosts, {
      params: { category: catId.toLowerCase() },
      props: { 
        categoryData: categoryEntry?.data || { name: catId, description: "" },
      },
      pageSize: 10,
    });
  }));

  return paths.flat();
}

const { page, categoryData } = Astro.props;
---

<BaseLayout 
  title={categoryData.name} 
  description={categoryData.description}
  image={categoryData.image} 
>
  <header class="mb-12">
    <a href="/categories" class="text-blue-600 hover:underline mb-4 inline-block">← Todas as categorias</a>
    
    {/* HERO DA CATEGORIA COM IMAGEM */}
    <div class="relative h-64 md:h-80 rounded-2xl overflow-hidden mb-6 bg-gray-900">
      <div class="relative h-64 md:h-80 rounded-2xl overflow-hidden mb-6 bg-gray-900">
        {categoryData.image && (
          <img 
            src={categoryData.image.url} 
            alt={categoryData.image.alt} 
            class="absolute inset-0 w-full h-full object-cover" 
          />
        )}
      </div>
      <div class="absolute inset-0 flex flex-col justify-end p-8">
        <h1 class="text-4xl md:text-6xl font-black text-white capitalize mb-2">
          {categoryData.name}
        </h1>
        {categoryData.description && (
          <p class="text-gray-200 max-w-2xl text-lg line-clamp-2">
            {categoryData.description}
          </p>
        )}
      </div>
    </div>
    
    <p class="text-sm text-gray-500 font-medium tracking-wide uppercase">
      Página {page.currentPage} de {page.lastPage}
    </p>
  </header>

  <section class="space-y-10">
    {page.data.map(post => (
      <article class="flex flex-col md:flex-row gap-6 items-start group">
        <div class="w-full md:w-64 h-40 overflow-hidden rounded-lg">
           <img 
            src={post.data.image.url} 
            alt={post.data.image.alt}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
          />
        </div>
        <div class="flex-1">
          <h2 class="text-2xl font-bold group-hover:text-blue-600 transition-colors mb-2 leading-tight">
            <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
          </h2>
          <p class="text-gray-600 line-clamp-3">{post.data.description}</p>
        </div>
      </article>
    ))}
  </section>

  {/* PAGINAÇÃO */}
  <nav class="mt-16 flex justify-between items-center border-t border-gray-100 pt-8">
    {page.url.prev ? (
      <a href={page.url.prev} class="flex items-center gap-2 font-bold text-blue-600 hover:translate-x-[-4px] transition-transform">
        ← Anterior
      </a>
    ) : <div />}
    
    <div class="flex gap-2">
       {/* Aqui você poderia renderizar números de página se quisesse */}
    </div>

    {page.url.next ? (
      <a href={page.url.next} class="flex items-center gap-2 font-bold text-blue-600 hover:translate-x-[4px] transition-transform">
        Próxima →
      </a>
    ) : <div />}
  </nav>
</BaseLayout>